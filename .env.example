# GeekHub Bot — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyala ve değerleri doldur:
#   copy .env.example .env

# Discord bot token'ı (Discord Developer Portal > Bot > Token)
DISCORD_TOKEN=token_buraya_yaz

# Bot'un uygulama ID'si (Discord Developer Portal > General Information > Application ID)
CLIENT_ID=application_id_buraya_yaz

# Hoş geldin mesajlarının gönderileceği kanal ID'si
# (Kanalın üzerine sağ tıkla > ID'yi Kopyala — Geliştirici Modu açık olmalı)
WELCOME_CHANNEL_ID=kanal_id_buraya_yaz
